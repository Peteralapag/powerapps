	$sqlInsert = "INSERT INTO tbl_system_permission (`idcode`,`acctname`,`username`,`userlevel`,`applications`,`modules`,`p_view`)";
	$sqlInsert .= "VALUES('$idcode','$acctname','$username','10','FD Branch Ordering System','My Orders','1')";
